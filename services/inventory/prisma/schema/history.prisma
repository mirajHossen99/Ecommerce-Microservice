enum ActionType {
    IN
    OUT
}

model History {
    id              String     @id @default(cuid())
    actionType      ActionType
    quantityChanged Int
    lastQuantity    Int
    newQuantity     Int
    
    inventoryId     String
    inventory       Inventory  @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

    createdAt       DateTime   @default(now())
    updatedAt       DateTime   @updatedAt
}
